# Database (PostgreSQL). For local dev you can use Docker or Neon free tier.
# Supabase: use the pooler URL and add &pgbouncer=true (or rely on db.ts auto-append for *.supabase.*).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gluci?schema=public"

# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
# Optional: where /r/{shareRef} redirects (growth / app install page)
MARKETING_SITE_URL=https://gluci.app

# OpenAI (required for chat)
OPENAI_API_KEY=sk-...

# USDA FoodData Central (optional — DEMO_KEY works for light testing; fooddatacentral.usda.gov)
USDA_API_KEY=

# JWT for email/password sign-in (use a long random string in production)
JWT_SECRET=change_me_in_production_use_openssl_rand

# Free tier: food decisions before paywall
FREE_DECISIONS_LIMIT=50

# Telegram: create bot with @BotFather, set webhook to PUBLIC_BASE_URL/webhooks/telegram
TELEGRAM_BOT_TOKEN=

# WhatsApp Cloud API (Meta Developer)
WHATSAPP_VERIFY_TOKEN=your_random_verify_string
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=optional_for_signature_validation

# Stripe (paywall)
# 1) STRIPE_SECRET_KEY: dashboard.stripe.com -> Developers -> API keys -> Secret key (sk_test_... or sk_live_...)
# 2) STRIPE_PRICE_ID:   create a recurring Product+Price -> copy the Price ID (price_...)
# 3) STRIPE_WEBHOOK_SECRET: Developers -> Webhooks -> add endpoint
#    URL:   {PUBLIC_BASE_URL}/webhooks/stripe
#    Events: checkout.session.completed, customer.subscription.created,
#            customer.subscription.updated, customer.subscription.deleted, invoice.payment_failed
#    Copy the "Signing secret" (whsec_...)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Cron / internal jobs (set on host, call GET /internal/cron/reengage)
CRON_SECRET=change_me_long_random

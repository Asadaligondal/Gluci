generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  email                String?   @unique
  passwordHash         String?
  appToken             String?   @unique
  telegramChatId       String?   @unique
  whatsappWaId         String?   @unique
  /// One-time /link code for tying Telegram or WhatsApp to this app user (15 min)
  linkCode             String?   @unique
  linkCodeExpiresAt    DateTime?
  freeChecksUsed       Int       @default(0)
  subscriptionStatus   String    @default("free")
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionPriceId  String?
  subscriptionCurrentPeriodEnd DateTime?
  subscriptionCancelAtPeriodEnd Boolean @default(false)
  reengagementOptOut   Boolean   @default(false)
  /// Minimum whole days between automated re-engagement pings (1–30).
  reengagementFrequencyDays Int   @default(1)
  lastReengagementAt   DateTime?
  /// Opaque referral code for share links (`GET /r/:shareRef`).
  shareRef             String?   @unique
  /// Android first-run coach marks completed.
  appOnboardingComplete Boolean  @default(false)
  telegramOnboardingSent Boolean @default(false)
  whatsappOnboardingSent Boolean @default(false)
  profile              Profile?
  messages             Message[]
  usageEvents          UsageEvent[]
  conversations        Conversation[]
  analyticsEvents      AnalyticsEvent[]
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name       String
  properties Json?
  source     String

  @@index([userId])
  @@index([name, createdAt])
}

model Conversation {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title              String   @default("New chat")
  /// "telegram" | "whatsapp" for the single thread per user per channel; null = app-originated chats
  messagingChannel   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  messages           Message[]

  @@index([userId])
  @@unique([userId, messagingChannel])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal        String?
  dietaryJson String?  // JSON string: preferences, allergies
  memoryJson  String?  // JSON string: structured memory for LLM
}

model Message {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Legacy rows may be null before backfill; new writes always set this
  conversationId  String?
  conversation    Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            String
  content         String   @db.Text
  imageUrl        String?
  metadata        String?  // JSON
  createdAt       DateTime @default(now())

  @@index([conversationId])
  @@index([userId, conversationId])
}

model UsageEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  score     Float?
  verdict   String?
  createdAt DateTime @default(now())
}

/** Glycemic index reference foods (seed via seed_gi.py). */
model GiFood {
  id             Int     @id @default(autoincrement())
  name           String
  name_lower     String  @unique
  gi_value       Float
  carbs_per_100g Float?
  category       String?
  source         String  @default("auto")

  @@index([name_lower])
  @@map("gi_food")
}

/// Seeded Instagram RAG rows; `embedding` uses pgvector (managed via SQL / seed script).
model InstagramKnowledge {
  id                   Int     @id @default(autoincrement())
  account              String
  date                 String?
  caption              String?
  foods                String[]
  glucose_impact       String?
  spike_estimate_mg_dl Int?
  verdict              String?
  score                Int?
  key_tip              String?
  likes                Int?
  url                  String?
  embedding            Unsupported("vector(1536)")?

  @@map("instagram_knowledge")
}
